# ── SustainHub Backend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in values before running.

# Database
DATABASE_URL=postgresql+asyncpg://sustainhub:password@localhost:5432/sustainhub

# JWT Auth
SECRET_KEY=change-this-to-a-random-64-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxx

# Email — Resend
RESEND_API_KEY=re_xxxxxxx
DEMO_NOTIFY_EMAIL=demo@sustainhub.online

# OpenAI (AI Copilot / Report Builder)
OPENAI_API_KEY=sk-xxxxxxx
OPENAI_MODEL=gpt-4o

# AWS S3 (file uploads)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=sustainhub-uploads
# AWS_REGION=eu-west-2

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://sustainhub.online

# Sentry (optional)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Environment
ENVIRONMENT=production
