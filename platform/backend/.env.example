# ── SustainHub Backend Environment Variables ──────────────────────────────
# Copy this file to .env and fill in values before running.

# Database
DATABASE_URL=postgresql+asyncpg://sustain:sustain@localhost:5432/sustain

# Redis
REDIS_URL=redis://localhost:6379

# JWT Auth
SECRET_KEY=change-this-to-a-random-64-char-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Anthropic (AI Report Writer — Claude claude-sonnet-4-6)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe
STRIPE_SECRET_KEY=sk_live_xxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxx

# Email — Resend
RESEND_API_KEY=re_xxxxxxx
DEMO_NOTIFY_EMAIL=demo@sustainhub.online

# SMTP (alternatif e-posta)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# OpenAI (AI Copilot / Report Builder)
OPENAI_API_KEY=sk-xxxxxxx
OPENAI_MODEL=gpt-4o

# AWS S3 (file uploads)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_BUCKET_NAME=sustainhub-uploads
# AWS_REGION=eu-west-2

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://sustainhub.online

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_AI_PER_HOUR=20

# Sentry (optional)
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Environment
ENVIRONMENT=development

